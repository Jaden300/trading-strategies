// RMA ATR Bands Strategy — Long Only, Cross-Asset Optimized
//
// HOW IT WORKS:
//   Draws an asymmetric ATR channel around an RMA of the HIGH price.
//   When close breaks ABOVE the upper band → trend flips bullish → go long.
//   When close breaks BELOW the lower band → trend flips bearish → exit long.
//   Signals only fire on a trend CHANGE, not every bar inside the band.
//
// OPTIMIZED VALUES (10 stocks: NVDA GOOG AAPL MSFT AMZN AVGO META TSLA AMD NFLX)
// Test window: Jan 2021 → Apr 2026  |  $1,500 capital  |  33% per trade  |  Long only
// Conservative reopt (win-rate-weighted score)
// Mean Sharpe 0.494  |  Win rate 63.5%  |  57 trades / 197d avg hold  |  Avg return +56%
// Per-stock $1500: NVDA→$4907  GOOG→$1611  AAPL→$1562  MSFT→$1715
//                  AMZN→$1430  AVGO→$3698  META→$1964  TSLA→$1788  AMD→$2267  NFLX→$2510

//@version=6
strategy("RMA ATR Bands (Long Only)", overlay=true,
         initial_capital=1500,
         commission_type=strategy.commission.percent,
         commission_value=1.5,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=33,
         calc_on_every_tick=false)

// ── Inputs ────────────────────────────────────────────────────────────────────

grp0 = "Date Filter"
startDate = input.time(timestamp("2024-04-01"), "Start Date", group=grp0)

grp1 = "Band Settings"
maSrcInput  = input.string("close", "MA Source",  options=["close", "high", "hl2"], group=grp1)
maLength    = input.int   (8,       "MA Length",  minval=1,   group=grp1)
atrLength   = input.int   (20,      "ATR Length", minval=1,   group=grp1)
upperMult   = input.float (1.50,    "Upper Mult", step=0.05,  group=grp1)
lowerMult   = input.float (2.50,    "Lower Mult", step=0.05,  group=grp1)

grp2 = "Exit"
maExit      = input.bool(false, "MA Exit (shorter holds)", group=grp2,
              tooltip="Exit when price drops back to the MA instead of waiting for the lower band. ~5-7 week holds vs ~10 month holds.")

grp3 = "Display"
showSignals = input.bool(true, "Show Signals", group=grp3)
colorBars   = input.bool(true, "Color Bars",   group=grp3)

// ── Indicators ────────────────────────────────────────────────────────────────

maSrc = switch maSrcInput
    "high" => high
    "hl2"  => hl2
    =>        close

ma  = ta.rma(maSrc, maLength)
atr = ta.atr(atrLength)

upperLine = ma + atr * upperMult
lowerLine = ma - atr * lowerMult

// ── Trend state ───────────────────────────────────────────────────────────────

var int trend = 0

if close > upperLine and barstate.isconfirmed
    trend := 1

if close < lowerLine and barstate.isconfirmed
    trend := -1

longSignal  = trend == 1  and trend[1] != 1
exitSignal  = trend == -1 and trend[1] != -1

// MA exit: fires when price drops back to MA while we're in a long
maExitSignal = maExit and strategy.position_size > 0 and close < ma

// ── Execution (gated by start date) ──────────────────────────────────────────

inDateRange = time >= startDate

if longSignal and inDateRange
    strategy.entry("Long", strategy.long, comment="LONG")

if (exitSignal or maExitSignal) and inDateRange
    strategy.close("Long", comment=maExitSignal ? "MA EXIT" : "EXIT")

// ── Visuals ───────────────────────────────────────────────────────────────────

longColor  = color.rgb(57, 255, 20)
exitColor  = color.rgb(138, 43, 226)
bandColor  = trend == 1 ? longColor : trend == -1 ? exitColor : color.gray

plot(ma,        "MA",         color=bandColor, linewidth=2)
plot(upperLine, "Upper Band", color=bandColor)
plot(lowerLine, "Lower Band", color=bandColor)
fill(plot(upperLine, display=display.none), plot(lowerLine, display=display.none),
     color=color.new(bandColor, 90), title="Band Fill")

plotshape(showSignals and longSignal and inDateRange,
     style=shape.triangleup, location=location.belowbar,
     color=longColor, text="LONG", size=size.small)

plotshape(showSignals and (exitSignal or maExitSignal) and inDateRange
     and strategy.position_size[1] > 0,
     style=shape.triangledown, location=location.abovebar,
     color=exitColor, text="EXIT", size=size.small)

barcolor(colorBars ? bandColor : na)

// ── Confidence score (display only — does not affect strategy logic) ──────────
//   breakoutStr: how far above the upper band close is, in ATR units (capped at 3)
//   atrRank:     where today's ATR sits vs the last 63 bars (0 = weakest, 100 = strongest)
//   Average of both → 0-100 confidence. Only meaningful when trend is bullish.

breakoutStr  = math.min((close - upperLine) / atr, 3.0) / 3.0 * 100
atrRank      = ta.percentrank(atr, 63)
confidence   = math.round((breakoutStr + atrRank) / 2)

confStr  = trend == 1 ? str.tostring(confidence) + " / 100" : "—"
confCol  = trend != 1 ? color.gray :
           confidence >= 70 ? color.green :
           confidence >= 40 ? color.yellow : color.red

// ── Info table ────────────────────────────────────────────────────────────────

var table info = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    table.cell(info, 0, 0, "MA Src",     text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 0, maSrcInput,   text_color=color.white)
    table.cell(info, 0, 1, "Upper ×",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 1, str.tostring(upperMult, "#.##"), text_color=color.green)
    table.cell(info, 0, 2, "Lower ×",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 2, str.tostring(lowerMult, "#.##"), text_color=color.red)
    table.cell(info, 0, 3, "MA Exit",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 3, maExit ? "ON" : "OFF",
               text_color=maExit ? color.yellow : color.gray)
    table.cell(info, 0, 4, "Direction",  text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 4, "Long only",  text_color=color.green)
    table.cell(info, 0, 5, "Position",   text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 5, "33% / trade", text_color=color.yellow)
    table.cell(info, 0, 6, "Fee",        text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 6, "1.5% / leg", text_color=color.yellow)
    table.cell(info, 0, 7, "Confidence", text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 7, confStr,      text_color=confCol)
