// EMA Trail Strategy — Long Only, Cross-Asset Optimized
//
// HOW IT WORKS:
//   Enters when the fast EMA crosses above the slow EMA (trend just turned bullish).
//   Sets an initial TP and SL from entry. As price moves in your favour, both the
//   TP and SL ratchet upward — locking in profit while letting winners run.
//   A trailing iteration counter shows how well-established the trend is.
//
// Entry:
//   EMA(fast) crosses above EMA(slow)   — bullish crossover
//   → long at next bar's open
//
// Exit (whichever fires first, checked at bar close):
//   close >= tp_level                   — take profit hit
//   close <= sl_level                   — stop loss hit
//
// Trailing (once per bar when condition met):
//   close >= ref_price × (1 + trail_trigger%)
//   → tp_level  × (1 + trail_step%)    — target ratchets up
//   → sl_level  × (1 + trail_step%)    — floor ratchets up
//   → ref_price × (1 + trail_trigger%) — reference steps up
//
// OPTIMIZED VALUES (10 stocks: NVDA GOOG AAPL MSFT AMZN AVGO META TSLA AMD NFLX)
// Test window: Jan 2021 → Apr 2026  |  $1,500 capital  |  33% per trade  |  Long only
// Fast=10  Slow=50  TP=30%  SL=10%  Trail trigger=6%  Trail step=4%
// Score=0.500  |  Mean Sharpe=0.662  |  Avg return +48.8%  |  all 10 tickers profitable
// Per-stock $1500: NVDA→$3459  GOOG→$2181  AAPL→$1693  MSFT→$1934
//                  AMZN→$1758  AVGO→$2809  META→$2533  TSLA→$1493  AMD→$2290  NFLX→$2166

//@version=6
strategy("EMA Trail (Long Only)", overlay=true,
         initial_capital=1500,
         commission_type=strategy.commission.percent,
         commission_value=1.5,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=33,
         calc_on_every_tick=false,
         process_orders_on_close=true)

// ── Inputs ────────────────────────────────────────────────────────────────────

grp0 = "Date Filter"
startDate = input.time(timestamp("2021-01-01"), "Start Date", group=grp0)

grp1 = "EMA Settings"
fastLen = input.int(10, "Fast EMA", minval=2,  maxval=50,  group=grp1)
slowLen = input.int(50, "Slow EMA", minval=10, maxval=200, group=grp1)

grp2 = "TP / SL"
tpPct = input.float(30.0, "Initial TP %", minval=5.0,  maxval=100.0, step=1.0, group=grp2) / 100
slPct = input.float(10.0, "Initial SL %", minval=2.0,  maxval=30.0,  step=1.0, group=grp2) / 100

grp3 = "Trailing"
trailTrigger = input.float(6.0, "Trail Trigger %", minval=1.0, maxval=30.0, step=1.0, group=grp3,
              tooltip="Start trailing once price moves this % above reference price.") / 100
trailStep    = input.float(4.0, "Trail Step %",    minval=1.0, maxval=20.0, step=1.0, group=grp3,
              tooltip="Ratchet TP and SL up by this % each trail iteration.") / 100

grp4 = "Display"
showSignals = input.bool(true, "Show Signals",   group=grp4)
showLevels  = input.bool(true, "Show TP/SL",     group=grp4)
colorBars   = input.bool(true, "Color Bars",     group=grp4)

// ── Indicators ────────────────────────────────────────────────────────────────

fastEma = ta.ema(close, fastLen)
slowEma = ta.ema(close, slowLen)

crossUp = ta.crossover(fastEma, slowEma)

// ── Trailing state ────────────────────────────────────────────────────────────

var float tpLevel   = na
var float slLevel   = na
var float refPrice  = na
var int   trailIter = 0

inDateRange = time >= startDate
inPos       = strategy.position_size > 0

// ── Update trailing (before exit/entry checks) ────────────────────────────────

if inPos and not na(refPrice) and barstate.isconfirmed
    if close >= refPrice * (1.0 + trailTrigger)
        tpLevel    *= (1.0 + trailStep)
        slLevel    *= (1.0 + trailStep)
        refPrice   *= (1.0 + trailTrigger)
        trailIter  += 1

// ── Exit ──────────────────────────────────────────────────────────────────────

if inPos and inDateRange and barstate.isconfirmed
    if close <= slLevel
        strategy.close("Long", comment="STOP")
        tpLevel   := na
        slLevel   := na
        refPrice  := na
        trailIter := 0
    else if close >= tpLevel
        strategy.close("Long", comment="TARGET")
        tpLevel   := na
        slLevel   := na
        refPrice  := na
        trailIter := 0

// ── Entry ─────────────────────────────────────────────────────────────────────

if crossUp and not inPos and inDateRange and barstate.isconfirmed
    strategy.entry("Long", strategy.long, comment="LONG")
    tpLevel   := close * (1.0 + tpPct)
    slLevel   := close * (1.0 - slPct)
    refPrice  := close
    trailIter := 0

// ── Visuals ───────────────────────────────────────────────────────────────────

longColor = color.rgb(57, 255, 20)
exitColor = color.rgb(255, 165, 0)
tpColor   = color.rgb(57, 255, 20)
slColor   = color.rgb(255, 80, 80)

emaColor  = inPos ? longColor : color.gray

plot(fastEma, "Fast EMA", color=emaColor, linewidth=1)
plot(slowEma, "Slow EMA", color=emaColor, linewidth=2)

plot(showLevels and inPos ? tpLevel : na, "TP", color=tpColor,
     style=plot.style_linebr, linewidth=1)
plot(showLevels and inPos ? slLevel : na, "SL", color=slColor,
     style=plot.style_linebr, linewidth=1)

plotshape(showSignals and crossUp and inDateRange,
     style=shape.triangleup, location=location.belowbar,
     color=longColor, text="LONG", size=size.small)

plotshape(showSignals and strategy.position_size[1] > 0 and strategy.position_size == 0 and inDateRange,
     style=shape.triangledown, location=location.abovebar,
     color=exitColor, text="EXIT", size=size.small)

barcolor(colorBars ? (inPos ? longColor : na) : na)

// ── Confidence (trail iteration count → 0-100) ────────────────────────────────
//   Each trail iteration = price moved another trail_trigger% in your favour.
//   0 = fresh entry, no trail yet.  4+ = strongly trending, multiple ratchets.

confidence = math.min(trailIter * 25, 100)
confStr    = inPos ? str.tostring(confidence) + " / 100  (" + str.tostring(trailIter) + " trails)" : "—"
confCol    = not inPos      ? color.gray  :
             confidence >= 75 ? color.green  :
             confidence >= 25 ? color.yellow : color.white

// ── Info table ────────────────────────────────────────────────────────────────

var table info = table.new(position.top_right, 2, 9, border_width=1)

if barstate.islast
    table.cell(info, 0, 0, "Fast EMA",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 0, str.tostring(fastLen),                 text_color=color.white)
    table.cell(info, 0, 1, "Slow EMA",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 1, str.tostring(slowLen),                 text_color=color.white)
    table.cell(info, 0, 2, "Init TP",     text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 2, str.tostring(math.round(tpPct * 100, 0)) + "%",
               text_color=color.rgb(57, 255, 20))
    table.cell(info, 0, 3, "Init SL",     text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 3, str.tostring(math.round(slPct * 100, 0)) + "%",
               text_color=color.rgb(255, 80, 80))
    table.cell(info, 0, 4, "Trail Trig",  text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 4, str.tostring(math.round(trailTrigger * 100, 0)) + "%",
               text_color=color.yellow)
    table.cell(info, 0, 5, "Trail Step",  text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 5, str.tostring(math.round(trailStep * 100, 0)) + "%",
               text_color=color.yellow)
    table.cell(info, 0, 6, "Position",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 6, "33% / trade", text_color=color.yellow)
    table.cell(info, 0, 7, "Fee",         text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 7, "1.5% / leg",  text_color=color.yellow)
    table.cell(info, 0, 8, "Confidence",  text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 8, confStr,       text_color=confCol)
