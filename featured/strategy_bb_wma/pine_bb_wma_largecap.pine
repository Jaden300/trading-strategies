// Bollinger WMA Strategy — Long Only, Cross-Asset Optimized
//
// HOW IT WORKS:
//   Draws asymmetric Bollinger Bands around a Weighted Moving Average of hlc3.
//   Upper band (entry): basis + std_buy  × stddev   — tight, just above the mean
//   Lower band (exit):  basis − std_sell × stddev   — wide, only exits on major drops
//
//   Entry (close of bar → execute at next open):
//     hlc3 > upper band                  — breakout above the MA channel
//     AND (close > close[2] OR close > open)  — upward momentum / green candle
//     AND NOT (shadow > 10 × body)        — no doji/spinning-top candles
//     AND 1-bar cooldown after last exit
//
//   Exit (close of bar → execute at next open):
//     close < lower band                 — deep pullback below the WMA floor
//
//   No SL or TP — the wide lower band keeps you in during normal pullbacks.
//   Patience is the edge: avg hold ~1100 days at optimal params.
//
// OPTIMIZED VALUES (10 stocks: NVDA GOOG AAPL MSFT AMZN AVGO META TSLA AMD NFLX)
// Test window: Jan 2021 → Apr 2026  |  $1,500 capital  |  33% per trade  |  Long only
// Conservative reopt (win-rate-weighted score)
// BB Length=150  Std Buy=1.0  Std Sell=3.0
// Mean Sharpe=0.682  |  Win rate 86.7%  |  16 trades / 886d avg hold  |  Avg return +109%
// Per-stock $1500: NVDA→$8072  GOOG→$2723  AAPL→$1740  MSFT→$1908
//                  AMZN→$1826  AVGO→$5612  META→$2617  TSLA→$1664  AMD→$2807  NFLX→$2347

//@version=6
strategy("Bollinger WMA (Long Only)", overlay=true,
         initial_capital=1500,
         commission_type=strategy.commission.percent,
         commission_value=1.5,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=33,
         calc_on_every_tick=false)

// ── Inputs ────────────────────────────────────────────────────────────────────

grp0 = "Date Filter"
startDate = input.time(timestamp("2021-01-01"), "Start Date", group=grp0)

grp1 = "Band Settings"
bbLength = input.int  (150,  "WMA / BB Length", minval=5, group=grp1,
           tooltip="Period for the Weighted Moving Average and standard deviation.")
stdBuy   = input.float(1.0,  "Upper Band Mult (entry)", minval=0.01, step=0.05, group=grp1,
           tooltip="Entry fires when hlc3 breaks above basis + stdBuy × stddev.")
stdSell  = input.float(3.0,  "Lower Band Mult (exit)",  minval=0.5,  step=0.1,  group=grp1,
           tooltip="Exit fires when close drops below basis − stdSell × stddev.")

grp2 = "Display"
showSignals = input.bool(true, "Show Signals", group=grp2)
showBands   = input.bool(true, "Show Bands",   group=grp2)
colorBars   = input.bool(true, "Color Bars",   group=grp2)

// ── Indicators ────────────────────────────────────────────────────────────────

hlc3_val = (high + low + close) / 3.0

// Weighted Moving Average of hlc3
wmaSum    = 0.0
wmaWeight = 0.0
for i = 0 to bbLength - 1
    w         = float(bbLength - i)
    wmaSum   += nz(hlc3_val[i]) * w
    wmaWeight += w
basis = wmaSum / wmaWeight

// Population standard deviation of hlc3 (matches Pine ta.stdev with ddof=0 behaviour)
dev = ta.stdev(hlc3_val, bbLength)

upperBand = basis + stdBuy  * dev
lowerBand = basis - stdSell * dev

// ── Signals ───────────────────────────────────────────────────────────────────

inDateRange = time >= startDate
inPos       = strategy.position_size > 0

// Entry filters
closeGtClose2 = close > close[2]
closeGtOpen   = close > open
candleOk      = closeGtClose2 or closeGtOpen

body         = math.abs(close - open)
candleRange  = high - low
shadow       = candleRange - body
shadowOk     = not (body > 0 and shadow > 10.0 * body)

longSignal = hlc3_val > upperBand and candleOk and shadowOk

// Exit signal
exitSignal = close < lowerBand

// ── Execution (signal fires at bar close → execute at next open) ──────────────

var bool pendingEntry = false
var bool pendingExit  = false
var int  lastExitBar  = -999

if pendingExit and inPos
    strategy.close("Long", comment="EXIT")
    pendingExit  := false
    lastExitBar  := bar_index

if pendingEntry and not inPos
    strategy.entry("Long", strategy.long, comment="LONG")
    pendingEntry := false

// Exit signal at close
if inPos and not pendingExit and exitSignal and barstate.isconfirmed
    pendingExit := true

// Entry signal at close (1-bar cooldown after exit)
if not inPos and not pendingEntry and not pendingExit and barstate.isconfirmed
    if bar_index > lastExitBar and longSignal and inDateRange
        pendingEntry := true

// ── Visuals ───────────────────────────────────────────────────────────────────

longColor = color.rgb(57, 255, 20)
exitColor = color.rgb(255, 100, 0)
bandColor = inPos ? longColor : color.gray

pBasis = plot(showBands ? basis     : na, "Basis",       color=bandColor, linewidth=2)
pUpper = plot(showBands ? upperBand : na, "Upper Band",  color=color.new(longColor, 40), linewidth=1)
pLower = plot(showBands ? lowerBand : na, "Lower Band",  color=color.new(exitColor, 40), linewidth=1)

fill(pUpper, pBasis, color=color.new(longColor, 92), title="Upper Fill")
fill(pBasis, pLower, color=color.new(exitColor, 92), title="Lower Fill")

plotshape(showSignals and pendingEntry[1] and inDateRange,
     style=shape.triangleup, location=location.belowbar,
     color=longColor, text="LONG", size=size.small)

plotshape(showSignals and pendingExit[1] and inDateRange and strategy.position_size[1] > 0,
     style=shape.triangledown, location=location.abovebar,
     color=exitColor, text="EXIT", size=size.small)

barcolor(colorBars and inPos ? longColor : na)

// ── Confidence score ──────────────────────────────────────────────────────────
// Measures how far hlc3 is above the upper band (entry strength)
// and how far above the lower band price currently is (distance to exit)

entryStrength  = inPos ? math.min((hlc3_val - upperBand) / math.max(dev, 0.01), 3.0) / 3.0 * 100 : 0.0
distToExit     = inPos ? math.min((close - lowerBand)    / math.max(dev, 0.01), 10.0) / 10.0 * 100 : 0.0
confidence     = inPos ? math.round((entryStrength + distToExit) / 2) : 0

confStr = inPos ? str.tostring(confidence) + " / 100" : "—"
confCol = not inPos      ? color.gray  :
          confidence >= 70 ? color.green  :
          confidence >= 40 ? color.yellow : color.red

// ── Info table ────────────────────────────────────────────────────────────────

var table info = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    table.cell(info, 0, 0, "BB Length",    text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 0, str.tostring(bbLength),               text_color=color.white)
    table.cell(info, 0, 1, "Std Buy",      text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 1, str.tostring(stdBuy, "#.##"),          text_color=color.rgb(57, 255, 20))
    table.cell(info, 0, 2, "Std Sell",     text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 2, str.tostring(stdSell, "#.#"),          text_color=color.rgb(255, 100, 0))
    table.cell(info, 0, 3, "Basis",        text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 3, inPos ? str.tostring(math.round(basis, 2)) : "—",
               text_color=color.white)
    table.cell(info, 0, 4, "Lower Band",   text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 4, inPos ? str.tostring(math.round(lowerBand, 2)) : "—",
               text_color=color.rgb(255, 100, 0))
    table.cell(info, 0, 5, "Position",     text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 5, "33% / trade",  text_color=color.yellow)
    table.cell(info, 0, 6, "Fee",          text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 6, "1.5% / leg",   text_color=color.yellow)
    table.cell(info, 0, 7, "Confidence",   text_color=color.white, bgcolor=color.gray)
    table.cell(info, 1, 7, confStr,        text_color=confCol)
