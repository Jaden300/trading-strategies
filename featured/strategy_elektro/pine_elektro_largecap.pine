// Tetrad Elektro — Bollinger Band Mean-Reversion (Long Only, Cross-Asset Optimized)
//
// HOW IT WORKS:
//   Draws a wide Bollinger Band around a very slow SMA of price.
//   When close drops BELOW the lower band AND RSI is oversold → go long (buy the panic).
//   When close rises ABOVE the upper band AND RSI is overbought → exit long (sell the euphoria).
//   No TP/SL — patience: holds through full recovery cycles (avg ~700 days).
//
// OPTIMIZED VALUES (10 stocks: NVDA GOOG AAPL MSFT AMZN AVGO META TSLA AMD NFLX)
// Test window: Jan 2021 → Apr 2026  |  $1,500 capital  |  33% per trade  |  Long only
// Score 0.592  |  Mean Sharpe 0.742  |  Min Sharpe 0.347  |  Win rate 100%
// Avg return +116%  |  Avg drawdown -24%  |  ~1-2 entries per ticker over 5 years
// Per-stock $1500: NVDA→$8337  GOOG→$2696  AAPL→$2035  MSFT→$1887
//                  AMZN→$1848  AVGO→$5767  META→$2384  TSLA→$1928  AMD→$3386  NFLX→$2158

//@version=6
strategy("Tetrad Elektro BB (Long Only)", overlay=true,
         initial_capital=1500,
         commission_type=strategy.commission.percent,
         commission_value=1.5,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=33,
         calc_on_every_tick=false)

// ── Inputs ────────────────────────────────────────────────────────────────────

grp0 = "Date Filter"
startDate = input.time(timestamp("2021-01-01"), "Start Date", group=grp0)
endDate   = input.time(timestamp("2026-04-30"), "End Date",   group=grp0)

grpBB = "Bollinger Bands"
bbLength = input.int(350,  "BB Length",     minval=10,  group=grpBB)
bbMult   = input.float(1.5, "BB Multiplier", minval=0.5, step=0.1, group=grpBB)

grpRSI = "RSI"
rsiLength   = input.int(35,   "RSI Length",          minval=2,  group=grpRSI)
rsiOversold = input.float(40.0, "RSI Oversold (entry ≤)", step=1.0, group=grpRSI)
rsiExit     = input.float(80.0, "RSI Exit (exit ≥)",     step=1.0, group=grpRSI)

// ── Indicators ────────────────────────────────────────────────────────────────

basis = ta.sma(close, bbLength)
dev   = bbMult * ta.stdev(close, bbLength)
upper = basis + dev
lower = basis - dev

rsi = ta.rsi(close, rsiLength)

// ── Signals ───────────────────────────────────────────────────────────────────

inWindow = true

longEntry = inWindow and close <= lower and rsi <= rsiOversold
longExit  = close >= upper and rsi >= rsiExit

// ── Execution ─────────────────────────────────────────────────────────────────

if longEntry and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if longExit and strategy.position_size > 0
    strategy.close("Long", comment="BB Exit")

// ── Plots ─────────────────────────────────────────────────────────────────────

tetradBlue = color.rgb(0, 51, 255)
softBlue   = color.new(tetradBlue, 50)
basisColor = color.new(tetradBlue, 20)

pBasis = plot(basis, "BB Basis", color=basisColor,  linewidth=2)
pUpper = plot(upper, "BB Upper", color=softBlue,    linewidth=2)
pLower = plot(lower, "BB Lower", color=softBlue,    linewidth=2)

fill(pUpper, pLower, color=color.new(tetradBlue, 92), title="BB Fill")

isLong = strategy.position_size > 0
fill(pBasis, pLower,
     color=isLong ? color.new(tetradBlue, 80) : na,
     title="Long Fill")

plotshape(longEntry, title="Long Entry", style=shape.triangleup,
          location=location.belowbar, color=color.new(tetradBlue, 0),
          size=size.small)
plotshape(longExit and isLong, title="Long Exit", style=shape.triangledown,
          location=location.abovebar, color=color.new(color.orange, 0),
          size=size.small)

// ── Confidence score ──────────────────────────────────────────────────────────
// While in position: how far RSI has recovered from the oversold entry level
// toward the overbought exit level.  0 = just entered, 100 = ready to exit.

confidence = isLong ? math.round(math.max(0.0, math.min((rsi - rsiOversold) / math.max(rsiExit - rsiOversold, 1.0) * 100.0, 100.0))) : 0
confStr    = isLong ? str.tostring(confidence) + " / 100" : "—"
confCol    = not isLong        ? color.gray   :
             confidence >= 70  ? color.green  :
             confidence >= 40  ? color.yellow : color.white

// ── Info Table ────────────────────────────────────────────────────────────────

var table tbl = table.new(position.top_right, 2, 8,
     border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    table.cell(tbl, 0, 0, "Tetrad Elektro BB",   text_color=color.white,  bgcolor=tetradBlue,           text_size=size.small)
    table.cell(tbl, 1, 0, "Long Only",            text_color=color.white,  bgcolor=tetradBlue,           text_size=size.small)
    table.cell(tbl, 0, 1, "BB Length",            text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(bbLength), text_color=color.white,  bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 2, "BB Mult",              text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(bbMult, "#.#"), text_color=color.white, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 3, "RSI Length",           text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(rsiLength), text_color=color.white, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 4, "RSI Entry ≤",          text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(rsiOversold, "#.#"), text_color=color.white, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 5, "RSI Exit ≥",           text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(rsiExit, "#.#"), text_color=color.white, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 6, "TP/SL",                text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 6, "N/A — BB exit",        text_color=color.white,  bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 0, 7, "Confidence",            text_color=color.silver, bgcolor=color.new(color.gray,85), text_size=size.small)
    table.cell(tbl, 1, 7, confStr,                 text_color=confCol,      bgcolor=color.new(color.gray,85), text_size=size.small)
